# Obsidian app state — managed externally (enforce-graph-colors.sh, Obsidian itself)
.obsidian/

# Syncthing folder marker — filesystem only, not part of vault content
.stfolder

# Synced repo docs/diagrams — derived content, lives in each repo's own git history
repos/*/docs/
repos/*/diagrams/

# Git worktrees — isolated workspaces, never vault content
.worktrees/
